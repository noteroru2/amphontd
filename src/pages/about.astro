---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const siteName = import.meta.env.PUBLIC_SITE_NAME ?? 'AMPHON TRADING';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'AboutPage',
  name: `เกี่ยวกับเรา | ${siteName}`,
  description: 'ทำความรู้จักกับ AMPHON TRADING (อำพล เทรดดิ้ง) ผู้เชี่ยวชาญด้านการรับซื้อสินค้าไอทีมือสองด้วยประสบการณ์และความจริงใจ',
  url: `${site}/about/`,
};
---

<BaseLayout
  title="เกี่ยวกับเรา | AMPHON TRADING"
  description="รู้จักกับ AMPHON TRADING (อำพล เทรดดิ้ง) แพลตฟอร์มรับซื้อสินค้าไอทีมือสองที่เน้นความโปร่งใสและยุติธรรม"
  pathname="/about/"
  jsonLd={jsonLd}
>
  <article class="container longform">
    <header>
      <p class="eyebrow">About Us</p>
      <h1>รู้จักกับ AMPHON TRADING (อำพล เทรดดิ้ง)</h1>
      <p class="intro">
        จากจุดเริ่มต้นที่เป็นกลุ่มคนรักไอที สู่แพลตฟอร์ม <strong>AMPHON TRADING</strong> ที่มุ่งมั่นยกระดับตลาดซื้อขายสินค้าไอทีมือสองในไทยให้มีความเป็นธรรม โปร่งใส และปลอดภัยสำหรับทุกคน
      </p>
    </header>

    <section>
      <h2>ภารกิจของเรา (Mission)</h2>
      <p>เราไม่ได้มองว่าการรับซื้อคือการค้ากำไรสูงสุดเพียงอย่างเดียว แต่เรามองว่ามันคือการ "ส่งต่อความคุ้มค่า" และการช่วยให้คนไทยเข้าถึงสินค้าเทคโนโลยีได้ง่ายขึ้นผ่านการหมุนเวียนทรัพยากรอย่างมีประสิทธิภาพ</p>
      <ul>
        <li><strong>ความโปร่งใส:</strong> ทุกขั้นตอนการประเมินราคาต้องอธิบายเหตุผลได้</li>
        <li><strong>ความเป็นธรรม:</strong> ให้ราคาสูงตามสภาพสเปคจริง ไม่กดราคามั่วซั่ว</li>
        <li><strong>ความเร็ว:</strong> ตอบคำถามไว จ่ายเงินทันที ปิดดีลให้เร็วที่สุด</li>
      </ul>
    </section>

    <section>
      <h2>ทำไมต้องชื่อ "อำพล เทรดดิ้ง"?</h2>
      <p>ชื่อร้านของเราสื่อถึงความมั่นคงและความซื่อสัตย์ เราต้องการสร้างแบรนด์ที่คนไทยนึกถึงเป็นอันดับแรกเมื่อต้องการขายโน๊ตบุ๊ค ไอโฟน หรือคอมพิวเตอร์ โดยไม่ต้องกังวลเรื่องการถูกหลอกหรือถูกเอารัดเอาเปรียบ</p>
    </section>

    <section>
      <h2>ทีมงานมืออาชีพ</h2>
      <p>เรามีทีมงานที่เชี่ยวชาญด้าน Hardware โดยเฉพาะ ทำให้เราสามารถประเมินสเปกลึกๆ ของโน๊ตบุ๊คหรือคอมพิวเตอร์ประกอบได้อย่างแม่นยำ ไม่ว่าจะเป็นค่า TGP ของการ์ดจอ, ชนิดของชิป SSD หรือความสมบูรณ์ของเมนบอร์ด เราตรวจสอบอย่างละเอียดเพื่อให้ผู้ขายได้ราคาที่คุ้มค่าที่สุด</p>
    </section>

    <div class="highlight-box">
      <strong>ขอบคุณที่ไว้วางใจ:</strong> ทุกการซื้อขายกับเรา คือแรงผลักดันให้เราพัฒนาบริการให้ดียิ่งขึ้นไปอีกครับ
    </div>

    <section>
      <a href="/contact" class="inline-contact">ติดต่อเราเพื่อเริ่มประเมินราคา</a>
    </section>
  </article>
</BaseLayout>

<style>
  .eyebrow {
    color: var(--accent);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.9rem;
  }
</style>
