---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBox from '../components/ContactBox.astro';
import '../styles/longform.css';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'AMPHON TRADING';
const serviceAreasRaw =
	import.meta.env.PUBLIC_SERVICE_AREAS ??
	'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);

const faqItems = [
	{
		q: 'รับซื้อ MacBook รุ่นไหนบ้าง?',
		a: 'เรารับซื้อ MacBook ทุกรุ่น ทั้ง MacBook Air และ MacBook Pro ตั้งแต่รุ่นที่ใช้ชิป Intel ปี 2018 ขึ้นไป จนถึงรุ่นล่าสุดที่ใช้ Apple Silicon (M1, M2, M3, M4, M5 Series) ราคาประเมินอิงตามความต้องการของตลาด สเปก และสภาพจริง',
	},
	{
		q: 'MacBook เครื่องติดล็อกบริษัท (MDM) หรือติด iCloud รับซื้อไหม?',
		a: 'เครื่องที่ติดล็อกบริษัท (Mobile Device Management - MDM) หรือติด Activation Lock (iCloud) จะไม่สามารถรับซื้อในราคาปกติได้ครับ ผู้ขายต้องปลดล็อกให้เรียบร้อยก่อนส่งมอบ หากไม่สามารถปลดได้ เครื่องจะตีเป็นอะไหล่ซึ่งราคาจะต่ำมาก',
	},
	{
		q: 'รอบชาร์จแบตเตอรี่ (Cycle Count) มีผลต่อราคาแค่ไหน?',
		a: 'มีผลค่อนข้างชัดเจนครับ Cycle Count ที่สูง (เช่น เกิน 500-1000 รอบ ขึ้นอยู่กับรุ่น) หรือสถานะ Service Recommended บ่งบอกว่าแบตเตอรี่เสื่อมแล้ว เราจะต้องหักค่าเสื่อมตามต้นทุนการเปลี่ยนแบตเตอรี่ใหม่ของรุ่นนั้นๆ',
	},
	{
		q: 'MacBook จอลอก จอแตก หรือคีย์บอร์ดพิมพ์ไม่ติด รับซื้อไหม?',
		a: 'รับซื้อครับ แต่ราคาจะลดลงตามต้นทุนการเปลี่ยนอะไหล่ ตัวอย่างเช่น จอของ MacBook Pro รุ่นใหม่มีราคาสูงมาก หากจอแตกราคาประเมินจะถูกหักลบด้วยค่าเปลี่ยนจออย่างโปร่งใส แจ้งตำหนิก่อนประเมินจะช่วยให้ได้ราคาสุทธิที่แม่นยำ',
	},
	{
		q: 'มีกล่องและอุปกรณ์แท้ครบ ช่วยเพิ่มราคาไหม?',
		a: 'ช่วยได้ครับ เครื่องที่มีกล่องตรง Serial Number อะแดปเตอร์แท้ และสายชาร์จสภาพดี จะขายต่อได้ง่ายกว่า ทำให้เราสามารถประเมินให้ในราคาที่สูงกว่าเครื่องที่มีแต่ตัวเครื่องเปล่าๆ เล็กน้อย',
	},
	{
		q: 'ต้องเตรียมข้อมูลอะไรเพื่อประเมินให้เร็วที่สุด?',
		a: 'แนะนำให้ถ่ายรูปหน้าต่าง "About This Mac" (เกี่ยวกับ Mac เครื่องนี้) เพื่อโชว์รุ่น ชิป RAM สตอเรจ พร้อมถ่ายหน้า System Information ส่วนของ Battery (แสดง Cycle Count) และถ่ายรูปตัวเครื่องรอบด้าน ส่งมาทาง Line @webuy ครับ',
	},
	{
		q: 'อัปเกรด macOS ไม่ได้แล้ว ยังมีราคาไหม?',
		a: 'ยังมีราคาครับ แต่อาจจะจัดอยู่ในกลุ่มเครื่องใช้งานพื้นฐาน (Entry-level) ราคาจะลดหลั่นลงไปตามข้อจำกัดในการลงโปรแกรมเวอร์ชันใหม่ๆ',
	},
	{
		q: 'รับเงินช่องทางไหนบ้าง?',
		a: 'หลังจากตรวจเช็คเครื่องว่าตรงตามสภาพที่คุยกันไว้ เราจะโอนเงินเข้าบัญชีธนาคารของคุณเต็มจำนวนทันที ปลอดภัย รวดเร็ว และมีสลิปหลักฐานชัดเจน',
	},
	{
		q: 'อยู่ต่างจังหวัด ขาย MacBook ได้อย่างไร?',
		a: 'ง่ายมากครับ ทักแชทประเมินราคาผ่าน Line @webuy ให้เรียบร้อย เมื่อตกลงราคากันได้แล้ว คุณสามารถแพ็คเครื่องส่งพัสดุ (แนะนำให้ทำประกันพัสดุ) เมื่อทีมงานรับและเช็คเครื่องเสร็จ จะโอนเงินให้ทันทีครับ',
	},
];

const articleJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: 'รับซื้อ MacBook มือสอง ทุกรุ่น Air/Pro ให้ราคาดี ประเมินไว จ่ายสดทันที',
		description:
			'บริการรับซื้อ MacBook มือสองทุกรุ่น (Intel, M1, M2, M3, M4, M5) ประเมินราคาโปร่งใสตามชิปเซ็ต RAM SSD และ Cycle Count พร้อมคำแนะนำการเช็คเครื่องก่อนขาย',
		inLanguage: 'th-TH',
		author: { '@type': 'Organization', name: orgName },
		publisher: { '@type': 'Organization', name: orgName },
		mainEntityOfPage: `${site}/rab-sue-macbook/`,
		datePublished: '2026-03-25',
		dateModified: '2026-03-25',
		image: [new URL('/og-default.png', site).toString()],
		keywords:
			'รับซื้อ macbook, รับซื้อ MacBook Air, รับซื้อ MacBook Pro, ขาย macbook มือสอง, ประเมินราคา macbook, รับซื้อ macbook m3, รับซื้อ macbook m4, รับซื้อ macbook m5, ขายแมคบุ๊ค',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.q,
			acceptedAnswer: { '@type': 'Answer', text: item.a },
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'บริการรับซื้อ MacBook มือสอง',
		description:
			'รับซื้อ MacBook Air และ MacBook Pro มือสอง ทุกรุ่น (Intel & Apple Silicon) ประเมินราคาโปร่งใส จ่ายเงินโอนทันที ให้บริการทั่วประเทศ',
		provider: { '@type': 'Organization', name: orgName },
		areaServed: serviceAreas.map((area) => ({ '@type': 'AdministrativeArea', name: area })),
		serviceType: 'รับซื้อ MacBook มือสอง',
		url: `${site}/rab-sue-macbook/`,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
			{ '@type': 'ListItem', position: 2, name: 'รับซื้อ MacBook', item: `${site}/rab-sue-macbook/` },
		],
	},
];
---

<BaseLayout
	title="รับซื้อ MacBook มือสอง | Air/Pro ชิป M1-M5 ให้ราคาสูง | AMPHON TRADING"
	description="AMPHON TRADING รับซื้อ MacBook มือสองทุกรุ่น ทั้ง MacBook Air และ Pro ชิป Intel และ M-Series ประเมินตาม Cycle Count อย่างโปร่งใส จ่ายเงินทันที 24 ชม."
	pathname="/rab-sue-macbook"
	type="article"
	jsonLd={articleJsonLd}
>
	<article class="container longform">
		<header>
			<p class="kicker">MacBook Buyback Guide 2026</p>
			<h1>รับซื้อ MacBook มือสอง ครบทุกรุ่น (Air/Pro) อัปเดตราคาล่าสุด ให้ราคาสูง จ่ายเงินไว</h1>
			<p class="intro">
				อยากเปลี่ยน Mac เครื่องใหม่ หรือมี MacBook วางทิ้งไว้ไม่ได้ใช้? <strong>AMPHON TRADING</strong> บริการรับซื้อ MacBook มือสองครอบคลุมตั้งแต่รุ่น Intel เจนเก่า ไปจนถึงรุ่นเรือธงที่ใช้ชิป <strong>Apple Silicon (M1, M2, M3, M4, M5 Series)</strong> เราเข้าใจว่าสเปกของ Mac แตกต่างกันไปตาม Customization ไม่ว่าจะเป็นการอัปเกรด Unified Memory (RAM) หรือเพิ่มความจุ SSD เราจึงประเมินราคาตามสเปกจริงอย่างแม่นยำ พร้อมอธิบายเหตุผลการหักลบราคาตามรอบชาร์จ (Cycle Count) อย่างโปร่งใส ไม่กดราคามั่วซั่ว พร้อมให้บริการตลอด 24 ชั่วโมง ทักมาคุยรายละเอียดได้ที่ <a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">Line @webuy</a> หรือโทร <a class="phone-link" href="tel:0642579353">064-257-9353</a> ครับ
			</p>
		</header>

		<!-- ==================== Section 1 ==================== -->
		<section>
			<h2>เหตุผลที่ควรขาย MacBook กับเรา</h2>
			<p>
				การขายอุปกรณ์ระดับโปรอย่าง MacBook ต้องการความเชี่ยวชาญในการประเมิน เนื่องจากมูลค่าของ Unified Memory (RAM 16GB, 24GB, 36GB ฯลฯ) และ SSD ที่อัปเกรดมา รวมถึงประเภทของชิป (Pro, Max, Ultra) มีผลต่อราคาสูงมาก ร้านรับซื้อที่ไม่มีความรู้ลึกพออาจตีราคาเหมาเป็นรุ่นเริ่มต้น ทำให้คุณเสียเปรียบ
			</p>
			<h3>ความเชี่ยวชาญและความรวดเร็ว</h3>
			<ul>
				<li><strong>ประเมินละเอียดทุก CTO (Configure-to-Order)</strong>: เรารู้ดีว่า RAM ที่เพิ่มมามีมูลค่าสูงในยุค AI เราให้ราคาที่สมเหตุสมผลตามสเปกจริง</li>
				<li><strong>โปร่งใสเรื่องแบตเตอรี่และจอ</strong>: เราขอดู Cycle Count และสภาพจอ หากมีจุดเสื่อม เราจะอธิบายว่าต้องหักค่าเปลี่ยนเท่าไร ไม่ใช้อารมณ์กดราคา</li>
				<li><strong>รับมือกับเครื่องติด MDM หรือมีปัญหา</strong>: เรามีคำแนะนำชัดเจน และประเมินเป็นอะไหล่ให้หากเครื่องไม่สามารถใช้งานปกติได้</li>
				<li><strong>ระบบจ่ายเงินโอนทันใจ</strong>: ตรวจเครื่องเสร็จ จ่ายเงินเข้าบัญชีทันที ปิดดีลไว ไม่ต้องรอ</li>
			</ul>
		</section>

		<!-- ==================== Section 2 ==================== -->
		<section>
			<h2>ปัจจัยหลักที่ส่งผลต่อราคารับซื้อ MacBook</h2>
			<p>
				เราไม่ได้ดูแค่ปีที่ซื้อ แต่เราวิเคราะห์ลึกลงไปถึงสถานะฮาร์ดแวร์ ต่อไปนี้คือจุดที่ส่งผลต่อราคารับซื้อมากที่สุด:
			</p>

			<h3>1. สถาปัตยกรรมชิปเซ็ต (Apple Silicon vs Intel)</h3>
			<p>
				ในปัจจุบัน (ปี 2026) ชิปตระกูล <strong>M-Series (M3, M4, M5)</strong> ครองตลาดมือสองเป็นหลัก และมีมูลค่าสูงมาก โดยเฉพาะรุ่น M-Pro และ M-Max ส่วนเครื่องที่ใช้ชิป <strong>Intel</strong> แม้จะมีราคาลดลงตามอายุขัยการซัพพอร์ตซอฟต์แวร์ แต่ยังมีมูลค่าอยู่สำหรับผู้เริ่มต้น หรือเครื่องสำรอง เรารับซื้อทั้งคู่ครับ
			</p>

			<h3>2. Unified Memory (RAM) และ SSD</h3>
			<p>
				MacBook ยุคใหม่ไม่สามารถอัปเกรด RAM และ SSD ภายหลังได้ เครื่องที่อัปเกรด RAM มาเป็น 16GB, 24GB, 36GB หรือ 64GB จะเป็นที่ต้องการในตลาดโปร (ตัดต่อวิดีโอ, ทำเพลง, รัน AI โมเดล) ทำให้ได้ราคาสูงกว่า Base Model อย่างเห็นได้ชัด
			</p>

			<h3>3. สุขภาพแบตเตอรี่ (Cycle Count & Condition)</h3>
			<p>
				วิธีเช็คง่ายๆ คือไปที่ <em>System Settings > General > About > System Report > Power</em> ดูบรรทัดที่เขียนว่า <strong>Cycle Count</strong> และ <strong>Condition</strong> (ปกติ, แนะนำให้รับบริการ) หากรอบชาร์จเกิน 500-1000 รอบ หรือสถานะแจ้งเตือนให้ Service ราคาประเมินจะถูกหักลบด้วยค่าเปลี่ยนแบตเตอรี่ใหม่
			</p>

			<h3>4. หน้าจอ (Display Condition)</h3>
			<p>
				จอของ MacBook โดยเฉพาะรุ่นจอ Liquid Retina XDR มีต้นทุนอะไหล่ที่แพงมาก หากมีรอยขีดข่วนลึก, ลอก (Staingate), เดดพิกเซล (Dead Pixel) หรือจอแตก จะกระทบราคาแรงที่สุด แนะนำให้ถ่ายรูปพื้นหลังสีขาวล้วนให้ทีมงานดูครับ
			</p>
			
			<h3>5. การล็อกระบบ (Activation Lock & MDM)</h3>
			<p>
				<strong>ต้องไม่มีการล็อก</strong> ใดๆ เครื่องต้องสามารถ Sign out จาก Apple ID, ปิด Find My Mac และรีเซ็ตกลับเป็นค่าโรงงานได้ หากเป็นเครื่ององค์กร ต้องปลด Profile MDM (Mobile Device Management) ออกให้หมดก่อนขาย
			</p>
		</section>

		<ContactBox heading="เช็คสเปก MacBook ของคุณแล้วใช่ไหม?" text="ส่งภาพ About This Mac และ Cycle Count มาประเมินราคาฟรีทาง Line @webuy ได้เลย" variant="primary" />

		<!-- ==================== Section 3 ==================== -->
		<section>
			<h2>การเตรียมตัวและการรีเซ็ต MacBook ก่อนขาย</h2>
			<p>
				เพื่อความปลอดภัยของข้อมูลส่วนตัวและเพิ่มความรวดเร็วในการตรวจรับ นี่คือขั้นตอนมาตรฐานที่คุณควรทำก่อนส่งมอบเครื่องให้เรา:
			</p>

			<h3>ขั้นตอนที่ 1: สำรองข้อมูล (Backup)</h3>
			<p>
				เสียบ External Drive แล้วเปิดแอป <strong>Time Machine</strong> ปล่อยให้ระบบแบคอัปข้อมูลทั้งหมด หรือโยนไฟล์งานสำคัญขึ้น iCloud Drive / Google Drive ให้เรียบร้อย
			</p>

			<h3>ขั้นตอนที่ 2: ปิด Find My Mac & ออกจาก Apple ID</h3>
			<p>
				ไปที่ <em>System Settings > [ชื่อของคุณ]</em> เลื่อนลงไปกด <strong>Sign Out</strong> ระบบจะถามรหัสผ่านเพื่อปิดการใช้งาน Find My Mac ขั้นตอนนี้จำเป็นมากเพื่อปลด Activation Lock
			</p>

			<h3>ขั้นตอนที่ 3: ยกเลิกการผูกบัญชีซอฟต์แวร์อื่นๆ (ถ้ามี)</h3>
			<p>
				หากคุณใช้โปรแกรมที่มี License ผูกกับเครื่อง เช่น Adobe Creative Cloud, Microsoft Office หรือปลั๊กอินทำเพลงต่างๆ อย่าลืม Sign out หรือ Deactivate เครื่องนี้ออกจากระบบด้วย
			</p>

			<h3>ขั้นตอนที่ 4: ลบข้อมูลทั้งหมด (Erase All Content and Settings)</h3>
			<p>
				สำหรับ macOS รุ่นใหม่ (Monterey ขึ้นไป) คุณสามารถไปที่ <em>System Settings > General > Transfer or Reset</em> แล้วเลือก <strong>Erase All Content and Settings</strong> กรอกรหัสผ่าน เครื่องจะลบข้อมูลและกลับไปสู่หน้าจอ "Hello" เหมือนซื้อใหม่ได้อย่างรวดเร็วและหมดจด
			</p>
			
			<div class="highlight-box">
