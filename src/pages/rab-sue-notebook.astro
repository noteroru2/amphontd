---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBox from '../components/ContactBox.astro';
import '../styles/longform.css';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'AMPHON TRADING';
const serviceAreasRaw =
	import.meta.env.PUBLIC_SERVICE_AREAS ??
	'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);

const faqItems = [
	{
		q: 'รับซื้อโน๊ตบุ๊คยี่ห้ออะไรบ้าง?',
		a: 'รับซื้อหลากหลายแบรนด์ ได้แก่ Dell, HP, Lenovo, ASUS, Acer, MSI, Razer, Microsoft Surface, Huawei รวมถึง AI PC / Copilot+ PC รุ่นใหม่ที่ใช้ชิป Snapdragon X Elite, Intel Core Ultra หรือ AMD Ryzen AI โดยพิจารณาจากสเปกและสภาพเครื่องเป็นหลัก (สำหรับ Apple ดูได้ที่หน้ารับซื้อ MacBook)',
	},
	{
		q: 'โน๊ตบุ๊คมีตำหนิ จอแตก หรือแบตเสื่อมยังขายได้ไหม?',
		a: 'ขายได้ครับ ทีมงานจะประเมินตามสภาพจริง โดยหักลบต้นทุนอะไหล่จอหรือแบตเตอรี่อย่างโปร่งใส แจ้งตำหนิตรง ๆ ตั้งแต่แรกจะช่วยให้ประเมินได้แม่นยำและไม่ต้องมาหักราคากันหน้างาน',
	},
	{
		q: 'โน๊ตบุ๊คยุค AI (Copilot+ PC) ราคาดีกว่ารุ่นปกติไหม?',
		a: 'ใช่ครับ โน๊ตบุ๊ครุ่นใหม่ที่มี NPU (Neural Processing Unit) สำหรับประมวลผล AI เช่น ชิปตระกูล Snapdragon X หรือ Core Ultra จะได้ราคาประเมินที่สูงกว่ารุ่นเก่าอย่างชัดเจน เพราะเป็นความต้องการใหม่ของตลาดในปี 2026',
	},
	{
		q: 'ติดต่อช่องทางไหนเร็วที่สุด?',
		a: 'แนะนำติดต่อผ่าน Line @webuy เพราะสามารถส่งรูปหน้าต่าง System Information (สเปก), Task Manager (NPU/GPU) และวิดีโอเครื่องได้ทันที ทำให้ประเมินได้รวดเร็ว หรือโทร 064-257-9353',
	},
	{
		q: 'ประเมินราคาใช้เวลานานไหม?',
		a: 'หากส่งรูปสเปก (CPU, RAM, สตอเรจ, การ์ดจอ) และตำหนิมาครบ ทีมงานสามารถประเมินราคาเบื้องต้นได้ภายใน 15-30 นาที',
	},
	{
		q: 'จ่ายเงินอย่างไรหลังตกลงราคา?',
		a: 'เมื่อตรวจรับเครื่องเสร็จและสภาพตรงตามที่แจ้ง เราโอนเงินผ่านบัญชีธนาคารให้เต็มจำนวนทันที ปลอดภัยและรวดเร็ว',
	},
	{
		q: 'อยู่ต่างจังหวัดขายได้ไหม?',
		a: 'ขายได้ครับ ทัก Line @webuy เพื่อประเมินราคาก่อน เมื่อตกลงกันได้สามารถแพ็คเครื่องส่งพัสดุ เมื่อของถึงเราตรวจเช็คเรียบร้อย โอนเงินให้ทันที (แนะนำให้ถ่ายวิดีโอตอนแพ็คและซื้อประกันพัสดุ)',
	},
	{
		q: 'โน๊ตบุ๊คเกมมิงกับโน๊ตบุ๊คทำงานราคาต่างกันอย่างไร?',
		a: 'โน๊ตบุ๊คเกมมิงที่มี GPU แยก (เช่น RTX 40-Series) มักได้ราคาสูงเพราะตอบโจทย์สายเกมและตัดต่อ ส่วนโน๊ตบุ๊คทำงานเกรดองค์กร (ThinkPad, EliteBook) ก็มีมูลค่าดีจากความทนทาน ราคาจริงขึ้นอยู่กับสเปกและสภาพครับ',
	},
];

const articleJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'Article',
		headline: 'รับซื้อโน๊ตบุ๊ค มือสอง ทุกยี่ห้อ (Gaming, AI PC, Ultrabook) ราคาดี จ่ายทันที',
		description:
			'บริการรับซื้อโน๊ตบุ๊คมือสองทุกยี่ห้อ (ASUS, Acer, Lenovo, Dell, MSI, HP) ครอบคลุมทั้ง Gaming Notebook และ AI PC (Copilot+) ประเมินตาม CPU, GPU, RAM, SSD อย่างโปร่งใส',
		inLanguage: 'th-TH',
		author: { '@type': 'Organization', name: orgName },
		publisher: { '@type': 'Organization', name: orgName },
		mainEntityOfPage: `${site}/rab-sue-notebook/`,
		datePublished: '2026-03-24',
		dateModified: '2026-03-24',
		image: [new URL('/og-default.png', site).toString()],
		keywords:
			'รับซื้อโน๊ตบุ๊ค, ขายโน๊ตบุ๊คมือสอง, ประเมินราคาโน๊ตบุ๊ค, รับซื้อ laptop, รับซื้อ notebook, รับซื้อ AI PC, รับซื้อโน๊ตบุ๊คเกมมิง, ขายโน๊ตบุ๊คได้ราคาดี, Copilot+ PC',
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
			{ '@type': 'ListItem', position: 2, name: 'รับซื้อโน๊ตบุ๊ค', item: `${site}/rab-sue-notebook/` },
		],
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqItems.map((item) => ({
			'@type': 'Question',
			name: item.q,
			acceptedAnswer: { '@type': 'Answer', text: item.a },
		})),
	},
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'บริการรับซื้อโน๊ตบุ๊คมือสอง',
		description:
			'บริการรับซื้อโน๊ตบุ๊คมือสองทุกยี่ห้อ ทุกรุ่น ประเมินราคาโปร่งใส จ่ายเงินโอนทันที ติดต่อ Line @webuy ตลอด 24 ชั่วโมง ให้บริการทั่วประเทศ',
		provider: { '@type': 'Organization', name: orgName },
		areaServed: serviceAreas.map((area) => ({ '@type': 'AdministrativeArea', name: area })),
		serviceType: 'รับซื้อโน๊ตบุ๊คมือสอง',
		url: `${site}/rab-sue-notebook/`,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'HowTo',
		name: 'วิธีขายโน๊ตบุ๊คมือสองกับ AMPHON TRADING',
		description: 'ขั้นตอนง่าย ๆ ในการขายโน๊ตบุ๊คมือสองให้ได้ราคาดีกับ AMPHON TRADING',
		step: [
			{ '@type': 'HowToStep', name: 'ส่งข้อมูลเครื่อง', text: 'แอดไลน์ @webuy แล้วส่งรูปสเปก (System Info) รูปรอบเครื่อง และตำหนิ' },
			{ '@type': 'HowToStep', name: 'รับราคาประเมิน', text: 'ทีมงานวิเคราะห์สเปกและแจ้งราคาประเมินเบื้องต้นให้อย่างโปร่งใส' },
			{ '@type': 'HowToStep', name: 'เตรียมเครื่อง', text: 'แบคอัพข้อมูล Sign out ออกจากบัญชีต่างๆ และ Reset Windows' },
			{ '@type': 'HowToStep', name: 'รับเงินทันที', text: 'ส่งมอบเครื่องผ่านจุดนัดพบ หรือพัสดุ ตรวจเช็คเสร็จรับเงินโอนทันที' },
		],
	},
];
---

<BaseLayout
	title="รับซื้อโน๊ตบุ๊ค (Notebook) มือสอง | Gaming, AI PC จ่ายสด | AMPHON TRADING"
	description="AMPHON TRADING รับซื้อโน๊ตบุ๊คมือสองทุกแบรนด์ ASUS, Acer, Lenovo, MSI, Dell ประเมินสเปกลึกถึง CPU/GPU (Core Ultra, Ryzen AI, RTX) จ่ายเงินทันที 24 ชม."
	pathname="/rab-sue-notebook"
	type="article"
	jsonLd={articleJsonLd}
>
	<article class="container longform">

		<header class="article-head">
			<p class="kicker">Notebook Buyback Guide 2026</p>
			<h1>รับซื้อโน๊ตบุ๊คมือสอง ทุกแบรนด์ (Gaming, Ultrabook, AI PC) ประเมินสเปกลึก จ่ายสดทันใจ</h1>
			<p class="intro">
				โลกของโน๊ตบุ๊คหมุนไวมาก โดยเฉพาะในปี 2026 ที่เต็มไปด้วย <strong>AI PC (Copilot+)</strong> และชิปเซ็ตเจนใหม่ๆ ทั้ง <strong>Intel Core Ultra, AMD Ryzen AI และ Snapdragon X Elite</strong> การขายโน๊ตบุ๊คเครื่องเก่าจึงต้องการผู้รับซื้อที่อัปเดตเทคโนโลยีและเข้าใจมูลค่าของสเปกเครื่องคุณอย่างแท้จริง ที่ AMPHON TRADING เรารับซื้อโน๊ตบุ๊ค (Windows Laptop) ทุกประเภท ไม่ว่าจะเป็นสาย <strong>Gaming (ROG, Legion, Predator)</strong>, สายทำงาน <strong>Business/Ultrabook (ThinkPad, XPS, Zenbook)</strong> หรือรุ่นระดับกลาง เราประเมินลึกถึงรหัส CPU, พลัง GPU และความจุ RAM/SSD เพื่อให้ได้ราคายุติธรรมที่สุด โอนเงินไว พร้อมให้บริการทั่วประเทศตลอด 24 ชั่วโมง ทักมาเลยที่ <a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">Line @webuy</a> 
			</p>
		</header>

		<!-- ═══════════════════════════════════════════════════════════ -->
		<section>
			<h2>
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;color:var(--accent)"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
				ทำไมการขายโน๊ตบุ๊คกับเรา ถึงได้ราคาที่เป็นธรรมกว่า
			</h2>
			<p>
				ร้านรับซื้อหลายแห่งตีราคาโน๊ตบุ๊คแบบเหมารวมแค่ชื่อรุ่น (เช่น ตีราคาเหมาเป็น i7) แต่ในความเป็นจริง Intel Core i7 มีหลายเจเนอเรชัน และมีรหัสห้อยท้าย (U, P, H, HX) ที่บอกถึงพลังการประมวลผลที่ต่างกันลิบลับ เราเข้าใจความต่างนี้ดี:
			</p>
			<ul>
				<li><strong>เจาะลึกสเปก:</strong> เราดูยัน TGP (ค่าการกินไฟของการ์ดจอ) เพราะ RTX 4060 เหมือนกัน แต่ถ้าวัตต์ต่างกัน ประสิทธิภาพและราคาก็ต่างกัน</li>
				<li><strong>ให้ค่ากับ NPU:</strong> เครื่องยุคใหม่ที่มีหน่วยประมวลผล AI (NPU) เราบวกมูลค่าเทคโนโลยีอนาคตให้</li>
				<li><strong>บอกเหตุผลที่หักราคา:</strong> แบตเสื่อม จอเบิร์น เราหักตามต้นทุนอะไหล่แบบมีอ้างอิง ไม่ใช่การกดราคาแบบขอไปที</li>
				<li><strong>จบไว โอนทันที:</strong> ไม่ต้องรอคิวเช็คเครื่องเป็นวัน เราตรวจระบบพื้นฐานผ่าน เช็คสเปกตรง โอนเงินเข้าบัญชีทันที</li>
			</ul>
		</section>

		<!-- ═══════════════════════════════════════════════════════════ -->
		<section>
			<h2>
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;color:var(--accent)"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
				เจาะลึก: 5 ชิ้นส่วนที่กำหนดราคาโน๊ตบุ๊ค (อัปเดต 2026)
			</h2>

			<h3>1. โปรเซสเซอร์ (CPU) & AI NPU</h3>
			<p>
				ปี 2026 คือยุคของ AI PC ชิปประมวลผลไม่ได้แข่งกันแค่คอร์ความเร็วอีกต่อไป แต่แข่งกันที่ <strong>NPU (Neural Processing Unit)</strong> หากโน๊ตบุ๊คของคุณใช้ชิปอย่าง <strong>Intel Core Ultra Series, AMD Ryzen AI 300 Series หรือ Snapdragon X Elite / X Plus</strong> (รองรับ Copilot+ PC) เครื่องของคุณจะเป็นที่ต้องการอย่างมากในตลาดมือสอง และได้ราคาสูงแน่นอน ส่วนเครื่องรุ่นเก่าที่ใช้ Core i Gen 11-13 หรือ Ryzen Gen 5000-7000 ก็ยังรับซื้อได้ แต่ราคาจะลดหลั่นกันไป
			</p>
			<h4>วิธีเช็ค CPU ง่ายๆ:</h4>
			<p>
				กด <code>Ctrl + Shift + Esc</code> เพื่อเปิด <strong>Task Manager</strong> > ไปที่แท็บ <strong>Performance</strong> > คลิกที่ <strong>CPU</strong> ถ่ายภาพหน้านี้ส่งมาให้เราได้เลย (ถ้าเป็นรุ่นใหม่ จะมีแถบ <strong>NPU</strong> แยกมาให้เห็นด้วย)
			</p>

			<h3>2. การ์ดจอแยก (Dedicated GPU) สำหรับสาย Gaming / Creator</h3>
			<p>
				GPU คือหัวใจของโน๊ตบุ๊คเกมมิ่ง ตระกูล <strong>NVIDIA GeForce RTX 40-Series (RTX 4050, 4060, 4070, 4080, 4090)</strong> ครองตลาดและรักษาราคาได้ดีที่สุด หากเป็น RTX 30-Series ก็ยังมีคนหาซื้อเรื่อยๆ ส่วนทางฝั่ง <strong>AMD Radeon RX 7000 Series Mobile</strong> ก็รับประเมินเช่นกัน
			</p>

			<h3>3. RAM & Storage (ยุคนี้ 16GB คือมาตรฐาน)</h3>
			<p>
				ปัจจุบันโน๊ตบุ๊คหลายรุ่น (โดยเฉพาะ Ultrabook และ AI PC) ฝัง RAM มากับบอร์ด (Soldered) อัปเกรดเพิ่มไม่ได้ ดังนั้นเครื่องที่มี RAM 16GB, 32GB หรือ 64GB (LPDDR5x) มาตั้งแต่โรงงานจะได้แต้มต่อราคาสูงมาก ส่วน SSD ควรจะเป็น M.2 NVMe Gen 4 ความจุ 512GB ถึง 1TB ขึ้นไป
			</p>

			<h3>4. คุณภาพหน้าจอ (Refresh Rate & OLED)</h3>
			<p>
				หน้าจอส่งผลต่อราคามือสองมาก:
				<br/>- <strong>สาย Gaming:</strong> หน้าจอ IPS ที่มี Refresh Rate สูงๆ (144Hz, 165Hz, 240Hz+) จะทำให้ราคาไม่ตก
				<br/>- <strong>สายทำงาน/Creator:</strong> หน้าจอ OLED, Mini-LED หรือจอความละเอียดสูง (2.5K, 3K, 4K) จะช่วยบวกมูลค่าได้เยอะ แต่ต้องระวังปัญหาภาพค้าง (Burn-in) ในจอ OLED ซึ่งเราจะต้องตรวจเช็คอย่างละเอียด
			</p>

			<h3>5. สุขภาพแบตเตอรี่ (Battery Health)</h3>
			<p>
				เครื่องสเปกแรงแค่นี้ก็เปล่าประโยชน์ถ้าต้องเสียบสายชาร์จตลอดเวลา โน๊ตบุ๊คเกมมิ่งมักแบตเสื่อมไว หากแบตบวมจนดัน Touchpad หรือเครื่องดับเองเมื่อถอดสายชาร์จ ราคาประเมินจะถูกหักค่าเปลี่ยนแบตเตอรี่แท้ของรุ่นนั้นๆ
			</p>
		</section>

		<!-- ═══════════════════════════════════════════════════════════ -->
		<section>
			<h2>
				<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:6px;color:var(--accent)"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
				แบรนด์โน๊ตบุ๊ค (Windows) ที่รับซื้อ
			</h2>
			<p><em>(สำหรับ Apple MacBook ดูรายละเอียดที่ <a href="/rab-sue-macbook">หน้ารับซื้อ MacBook</a>)</em></p>
