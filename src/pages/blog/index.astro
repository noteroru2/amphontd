---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { fetchPosts, isWordpressConfigured } from '../../lib/wordpress';

const configured = isWordpressConfigured();
const posts = configured ? await fetchPosts() : [];
const site = import.meta.env.SITE_URL ?? 'https://example.com';
const listJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'CollectionPage',
		name: 'บทความ | AMPHON TRADING',
		description: 'รวมบทความให้ความรู้เกี่ยวกับการรับซื้อสินค้าไอที ประเมินราคา และเทคนิคต่าง ๆ จาก AMPHON TRADING',
		url: `${site}/blog/`,
		inLanguage: 'th-TH',
		mainEntity: {
			'@type': 'ItemList',
			numberOfItems: posts.length,
			itemListElement: posts.slice(0, 50).map((post, index) => ({
				'@type': 'ListItem',
				position: index + 1,
				url: `${site}/${post.slug}/`,
				name: post.title.rendered.replace(/<[^>]+>/g, '').trim(),
			})),
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{ '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
			{ '@type': 'ListItem', position: 2, name: 'บทความ', item: `${site}/blog/` },
		],
	},
];
---

<BaseLayout
	title="บทความ | AMPHON TRADING"
	description="รวมบทความให้ความรู้เกี่ยวกับการรับซื้อสินค้าไอทีมือสอง ประเมินราคา เตรียมเครื่องก่อนขาย และเทคนิคได้ราคาดี จาก AMPHON TRADING"
	pathname="/blog/"
	jsonLd={listJsonLd}
>
	<div class="container page-head">
		<h1 class="page-title">บทความ</h1>
		<p class="intro">รวมบทความให้ความรู้เกี่ยวกับการรับซื้อสินค้าไอที วิธีประเมินราคา เตรียมเครื่องก่อนขาย และเทคนิคได้ราคาดี จาก AMPHON TRADING</p>
		{
			!configured ? (
				<p class="hint">
					ตั้งค่า <code>PUBLIC_WORDPRESS_URL</code> ใน <code>.env</code>{' '}
					เพื่อดึงโพสต์จาก WordPress
				</p>
			) : posts.length === 0 ? (
				<p class="hint">ยังไม่มีโพสต์ หรือ API ไม่สามารถเชื่อมต่อได้</p>
			) : (
				<p class="meta">{posts.length} บทความ</p>
			)
		}
	</div>

	{
		posts.length > 0 && (
			<div class="container grid">
				{posts.map((post) => (
					<PostCard post={post} />
				))}
			</div>
		)
	}
</BaseLayout>

<style>
	.page-head {
		padding-block: 2rem 1rem;
	}
	.page-title {
		margin: 0 0 0.5rem;
		font-size: clamp(1.5rem, 3vw, 2rem);
	}
	.intro {
		margin: 0 0 0.6rem;
		color: var(--muted);
		font-size: 0.95rem;
		max-width: 62ch;
	}
	.meta {
		margin: 0;
		color: var(--muted);
		font-size: 0.95rem;
	}
	.hint {
		margin: 0;
		color: var(--muted);
		max-width: 48ch;
	}
	.hint code {
		font-size: 0.9em;
		padding: 0.15em 0.4em;
		background: var(--surface);
		border-radius: 6px;
		color: var(--accent);
	}
	.grid {
		display: grid;
		gap: 1.25rem;
		padding-bottom: 4rem;
	}
	@media (min-width: 700px) {
		.grid {
			grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
		}
	}
</style>
