---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBox from '../components/ContactBox.astro';
import '../styles/longform.css';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'AMPHON TRADING';
const serviceAreasRaw =
  import.meta.env.PUBLIC_SERVICE_AREAS ??
  'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
  .split(',')
  .map((item) => item.trim())
  .filter(Boolean);

const faqItems = [
  {
    q: 'รับซื้อลำโพงบลูทูธยี่ห้อไหนบ้าง?',
    a: 'เน้นรับซื้อแบรนด์ยอดนิยมระดับโลกเป็นหลักครับ เช่น Marshall, JBL, Harman Kardon, Bose, B&O และ Sony โดยพิจารณาจากรุ่น สภาพเครื่อง และความสมบูรณ์ของอุปกรณ์',
  },
  {
    q: 'ลำโพง Marshall ไม่มีกล่องและใบเสร็จ รับซื้อไหม?',
    a: 'รับซื้อครับ แต่ทีมงานจะตรวจสอบอย่างละเอียดเพื่อแยกระหว่างของแท้กับของปลอม (OEM/Copy) หากเป็นของแท้ 100% ก็จะได้ราคาตามมาตรฐานตลาดมือสอง',
  },
  {
    q: 'แบตเตอรี่เสื่อม ชาร์จไม่เข้า หรือเปิดไม่ติดเลย รับไหม?',
    a: 'รับประเมินครับ แต่อาจจะต้องตีราคาเป็นอะไหล่ หรือหักลบต้นทุนในการเปลี่ยนแบตเตอรี่และซ่อมแซมบอร์ด ขอให้แจ้งอาการตามจริงตั้งแต่ตอนประเมินผ่านไลน์ได้เลยครับ',
  },
  {
    q: 'ดอกลำโพงเสียงแตก เบสบวม ขายได้ราคาไหม?',
    a: 'เสียงแตกเป็นปัญหาที่พบบ่อยในลำโพงที่เปิดดังสุดเป็นเวลานาน หากดอกลำโพงเสียหาย เราจะประเมินราคาตามต้นทุนอะไหล่ดอกลำโพงรุ่นนั้นๆ ครับ',
  },
  {
    q: 'อยู่ต่างจังหวัด จะขายลำโพงอย่างไรไม่ให้พังระหว่างขนส่ง?',
    a: 'เราแนะนำให้ห่อบับเบิ้ลหนาๆ รอบตัวลำโพง และใช้กล่องที่ใหญ่กว่าตัวลำโพงเล็กน้อย ยัดกระดาษหรือโฟมกันกระแทกให้แน่นไม่ให้ขยับได้ และควรซื้อประกันพัสดุกับบริษัทขนส่ง (Kerry, Flash, EMS) เสมอครับ',
  },
  {
    q: 'ประเมินราคานานไหม จ่ายเงินตอนไหน?',
    a: 'ประเมินราคาผ่าน Line @webuy ได้ภายใน 15-30 นาทีครับ เมื่อตกลงราคาและเราได้รับเครื่องตรวจเช็คสภาพเรียบร้อย จะโอนเงินเข้าบัญชีทันที',
  },
  {
    q: 'ลำโพงกันน้ำ (Waterproof) ถ้าน้ำเข้า ประเมินอย่างไร?',
    a: 'แม้ลำโพงจะระบุว่ากันน้ำ แต่หากยางซีลเสื่อมสภาพจนน้ำเข้าแผงวงจร ราคาจะตกลงมากครับ ทีมงานจะตรวจเช็คคราบน้ำและความชื้นที่พอร์ตชาร์จก่อนรับซื้อเสมอ',
  },
];

const jsonLd: Array<Record<string, unknown>> = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'รับซื้อลำโพงมือสอง JBL, Marshall, Harman Kardon ให้ราคาดี จ่ายสด',
    description:
      'บริการรับซื้อลำโพง Bluetooth มือสอง (Marshall Emberton/Acton, JBL Charge/PartyBox, Bose) ประเมินราคาฟรี โปร่งใสตามสภาพดอกลำโพง แบตเตอรี่ และรุ่น',
    inLanguage: 'th-TH',
    author: { '@type': 'Organization', name: orgName },
    publisher: { '@type': 'Organization', name: orgName },
    mainEntityOfPage: `${site}/rab-sue-lamphong/`,
    datePublished: '2026-03-25',
    dateModified: '2026-03-25',
    image: [new URL('/og-default.png', site).toString()],
    keywords:
      'รับซื้อลำโพง, รับซื้อลำโพง JBL, รับซื้อลำโพง Marshall, ขายลำโพงมือสอง, ประเมินราคาลำโพง, รับซื้อ Marshall Acton 3, รับซื้อ JBL PartyBox, รับซื้อ Harman Kardon',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'บริการรับซื้อลำโพง Bluetooth มือสอง',
    description:
      'รับซื้อลำโพงมือสองแบรนด์ดัง JBL, Marshall, Bose, Harman Kardon ประเมินราคาโปร่งใส จ่ายเงินโอนทันที ให้บริการทั่วประเทศ',
    provider: { '@id': `${site}/#organization` },    areaServed: serviceAreas.map((area) => ({ '@type': 'AdministrativeArea', name: area })),
    serviceType: 'รับซื้อลำโพงมือสอง',
    url: `${site}/rab-sue-lamphong/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
      { '@type': 'ListItem', position: 2, name: 'รับซื้อลำโพง', item: `${site}/rab-sue-lamphong/` },
    ],
  },
];
---

<BaseLayout
  title="รับซื้อลำโพง JBL / Marshall / Harman มือสอง จ่ายเงินทันที | AMPHON TRADING"
  description="AMPHON TRADING รับซื้อลำโพง Bluetooth มือสอง (Marshall, JBL, Harman, Bose) ประเมินราคาโปร่งใส จ่ายเงินทันที ติดต่อ Line @webuy ตลอด 24 ชั่วโมง"
  pathname="/rab-sue-lamphong"
  type="article"
  jsonLd={jsonLd}
>
  <article class="container longform">
    <header>
      <p class="kicker">Speaker Buyback Guide 2026</p>
      <h1>รับซื้อลำโพงมือสอง แบรนด์ดัง (Marshall, JBL, Harman Kardon, Bose) ให้ราคาดี จ่ายเงินไว</h1>
      <p class="intro">
        อัปเกรดลำโพงใหม่แล้ว หรือมีลำโพงวางฝุ่นจับไม่ได้เปิดฟัง? <strong>AMPHON TRADING</strong> รับซื้อลำโพง Bluetooth มือสอง แบรนด์ยอดนิยม ไม่ว่าจะเป็นสายคลาสสิกอย่าง <strong>Marshall (Emberton, Acton, Stanmore, Woburn)</strong> สายปาร์ตี้อย่าง <strong>JBL (Charge, Flip, PartyBox)</strong> หรือสายพรีเมียมอย่าง <strong>Harman Kardon และ Bose</strong> เราประเมินราคาตามรุ่น สภาพภายนอก และคุณภาพเสียงดอกลำโพงอย่างโปร่งใส พร้อมตรวจสอบของแท้อย่างเป็นระบบ ให้ราคาที่คุณพอใจ จ่ายเงินโอนทันที ทักมาสอบถามราคาก่อนได้ 24 ชม. ที่ <a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">Line @webuy</a> หรือโทร <a class="phone-link" href="tel:0642579353">064-257-9353</a>
      </p>
    </header>

    <!-- ==================== Section 1 ==================== -->
    <section>
      <h2>แบรนด์ลำโพงยอดนิยมที่เราเน้นรับซื้อ (อัปเดต 2026)</h2>
      <p>
        ตลาดลำโพงมือสองคึกคักมาก โดยเฉพาะแบรนด์ที่มีเอกลักษณ์เรื่องดีไซน์และเสียง นี่คือรุ่นยอดฮิตที่ขายง่ายและได้ราคาดี:
      </p>

      <h3>1. Marshall (คลาสสิกร็อก ดีไซน์หรู)</h3>
      <p>
        เป็นแบรนด์ที่มีของปลอมในตลาดเยอะที่สุด แต่ถ้าของคุณเป็นของแท้ (เช็คแอป Marshall Bluetooth ได้) จะได้ราคาดีมาก รุ่นยอดฮิตได้แก่:
        <br/>- <strong>Portable:</strong> Emberton II, Emberton III, Middleton, Kilburn II, Tufton
        <br/>- <strong>Home Bluetooth:</strong> Acton III, Stanmore III, Woburn III
      </p>

      <h3>2. JBL (สายปาร์ตี้ เบสแน่น กันน้ำ)</h3>
      <p>
        ตอบโจทย์วัยรุ่นและสายเอาท์ดอร์ แบตอึด ทนทาน:
        <br/>- <strong>Portable:</strong> Flip 6, Charge 5, Charge 6, Xtreme 3, Xtreme 4, Boombox 3
        <br/>- <strong>Party Series:</strong> PartyBox Encore, PartyBox 110, 310, 710
      </p>

      <h3>3. Harman Kardon & Bose</h3>
      <p>
        เน้นกลุ่มผู้ใหญ่ ดีไซน์มินิมอล เสียงนุ่มลึก:
        <br/>- <strong>Harman:</strong> Aura Studio 3/4, Onyx Studio 7/8, SoundSticks
        <br/>- <strong>Bose:</strong> SoundLink Flex, SoundLink Mini, SoundLink Revolve
      </p>
    </section>

    <!-- ==================== Section 2 ==================== -->
    <section>
      <h2>ปัจจัยหลักที่ส่งผลต่อราคารับซื้อลำโพงมือสอง</h2>
      <p>
        การตีราคาลำโพงไม่ได้ดูแค่หน้าตา แต่เราเช็ครายละเอียดเหล่านี้:
      </p>

      <h3>1. ความสมบูรณ์ของดอกลำโพง (Speaker Driver & Bass Radiator)</h3>
      <p>
        สำคัญที่สุด! หากเปิดเสียงดังสุดแล้วมีอาการ <strong>"เสียงแตก (Distortion)"</strong> หรือ <strong>"เบสกระพือ/เบสหาย"</strong> ราคาจะร่วงทันที เนื่องจากดอกลำโพงอาจจะขาดหรือเสื่อมสภาพจากการใช้งานหนัก
      </p>

      <h3>2. สุขภาพแบตเตอรี่ (สำหรับรุ่น Portable)</h3>
      <p>
        ลำโพงพกพาอายุ 2-3 ปีขึ้นไป แบตเตอรี่มักจะเริ่มเสื่อม หากชาร์จเต็มแต่เปิดฟังได้ไม่ถึง 1-2 ชั่วโมง หรือต้องเสียบสายตลอดเวลา เราจะหักค่าเสื่อมตามราคาแบตเตอรี่ทดแทน
      </p>

      <h3>3. ความแท้ (Authenticity)</h3>
      <p>
        ของแท้ 100% เท่านั้นที่จะได้ราคามาตรฐาน หากมีกล่อง ใบเสร็จจากศูนย์ไทย (เช่น Ash Asia, มหาจักร) จะทำให้ทีมงานทำงานง่ายขึ้น เสนอราคาได้สูงและเร็วขึ้น
      </p>

      <h3>4. สภาพภายนอก (Cosmetic Condition)</h3>
      <p>
        หนังหุ้มตู้ลำโพงขาด, ตะแกรงหน้าบุบ, โลโก้ลอก หรือปุ่มยางเสื่อมสภาพ (เหนียว/เปื่อย) มีผลต่อราคา เพราะส่งผลต่อความสวยงามซึ่งเป็นเหตุผลหลักที่คนซื้อมือสองตัดสินใจ
      </p>
    </section>

    <ContactBox heading="เช็คสเปกลำโพงของคุณแล้วใช่ไหม?" text="ถ่ายรูปตัวเครื่องและส่งวิดีโอเทสเสียง มาประเมินราคาฟรีทาง Line @webuy ได้เลย" variant="primary" />

    <!-- ==================== Section 3 ==================== -->
    <section>
      <h2>เช็กลิสต์ก่อนขายลำโพงให้ได้ราคาดีที่สุด</h2>
      <p>
        อยากได้ราคาประเมินแบบไม่โดนหักหน้างาน? ลองเช็คตาม 4 ข้อนี้ก่อนทักหาเรา:
      </p>
      <ol>
        <li><strong>เช็ดทำความสะอาด:</strong> ปัดฝุ่นตะแกรง เช็ดคราบเหนียวตามปุ่มกด ลำโพงที่ดูใหม่จะสะท้อนถึงการดูแลรักษาที่ดี</li>
        <li><strong>อัดวิดีโอเทสเสียง:</strong> ถ่ายคลิปประมาณ 30 วินาที เปิดเพลงที่มีเบสชัดเจน ลองปรับเพิ่ม-ลด Volume และปรับเบส/แหลม (ถ้ามี) ให้ทีมงานดู</li>
        <li><strong>รวบรวมอุปกรณ์:</strong> หากล่อง คู่มือ สายชาร์จ สาย AUX และอะแดปเตอร์แท้ (ถ้ามี) ยิ่งครบ ยิ่งได้ราคาเต็ม</li>
        <li><strong>ชาร์จแบตเตอรี่:</strong> หากต้องนัดรับ กรุณาชาร์จแบตให้มีไฟอย่างน้อย 50% เพื่อให้ทีมงานสามารถกดเปิดและทดสอบเชื่อมต่อ Bluetooth หน้างานได้ทันที</li>
      </ol>
      <div class="highlight-box">
        <strong>ข้อควรระวังเรื่องความชื้น:</strong> สำหรับลำโพงกันน้ำ (เช่น JBL Charge) หากเคยทำตกน้ำ ควรมั่นใจว่าพอร์ตชาร์จแห้งสนิทก่อนขาย เพราะหากมีความชื้นสะสม บอร์ดอาจมีปัญหาในอนาคต
      </div>
    </section>

    <!-- ==================== Section 4 ==================== -->
    <section>
      <h2>พื้นที่ให้บริการรับซื้อลำโพง</h2>
      <p>
        เรารับซื้อลำโพงจากทั่วประเทศ ด้วยรูปแบบบริการดังนี้:
      </p>
      <h3>1. กรุงเทพฯ และปริมณฑล</h3>
      <p>
        นัดหมายสถานที่รับเครื่อง ทีมงานตรวจเช็คเสียง แบตเตอรี่ และการเชื่อมต่อ เมื่อผ่านตามที่แจ้งไว้ โอนเงินเข้าบัญชีทันที ณ จุดนัดพบ
      </p>
      <h3>2. ลูกค้าต่างจังหวัด</h3>
      <p>
        ลูกค้าจาก {serviceAreas.filter(a => !['กรุงเทพมหานคร','ปริมณฑล'].includes(a)).join(', ')} สามารถแพ็คส่งพัสดุมาได้ แนะนำให้ <strong>ห่อบับเบิ้ลหนาเป็นพิเศษ</strong> โดยเฉพาะบริเวณมุมตู้ลำโพง และซื้อประกันพัสดุกับบริษัทขนส่ง เมื่อของมาถึงเราเช็คแล้วว่าเสียงปกติ บอร์ดไม่พัง โอนเงินเต็มจำนวนให้ทันทีครับ
      </p>
    </section>

    <!-- ==================== FAQ Section ==================== -->
    <section class="faq">
      <h2>คำถามที่พบบ่อย (FAQ) รับซื้อลำโพง</h2>
      {faqItems.map((item) => (
        <details>
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </section>

    <!-- ==================== Internal Links ==================== -->
    <section>
      <h2>มีสินค้าไอทีอย่างอื่นอยากโล๊ะด้วยไหม?</h2>
      <p>นอกจากลำโพงแล้ว AMPHON TRADING รับเหมาสินค้าไอทีครบวงจร:</p>
      <ul>
      	<li><a href="/evaluate-price">คู่มือประเมินราคา & ความปลอดภัย</a> — ข้อควรระวังก่อนขายสินค้าไอที</li>
      	<li><a href="/rab-sue-iphone">รับซื้อ iPhone</a> — อัปเดตราคาล่าสุด ให้ราคาสูง</li>
      	<li><a href="/rab-sue-ipad">รับซื้อ iPad</a> — iPad Air, Pro, Mini ทุกรุ่น</li>        <li><a href="/rab-sue-macbook">รับซื้อ MacBook</a> — Air, Pro (Intel & M-Series)</li>
        <li><a href="/rab-sue-notebook">รับซื้อ Notebook (Windows)</a> — เน้นแบรนด์ดัง สายทำงาน/เกมมิ่ง</li>
        <li><a href="/rab-sue-com">รับซื้อคอมพิวเตอร์ตั้งโต๊ะ</a> — PC, Workstation</li>
        <li><a href="/rab-sue-klong">รับซื้อกล้องและเลนส์</a> — DSLR, Mirrorless</li>
      </ul>
    </section>
  </article>

  <ContactBox
    heading="พร้อมเปลี่ยนลำโพงเก่าเป็นเงินสดแล้วหรือยัง?"
    text="ทักไลน์ ส่งรุ่น รูปถ่าย และวิดีโอเทสเสียง เพื่อรับราคาประเมินทันที!"
    ctaText="แอดไลน์ @webuy"
  />
</BaseLayout>
