---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactBox from '../components/ContactBox.astro';
import '../styles/longform.css';
import { getSiteOrigin } from '../lib/site';

const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'AMPHON TRADING';
const serviceAreasRaw =
  import.meta.env.PUBLIC_SERVICE_AREAS ??
  'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
  .split(',')
  .map((item) => item.trim())
  .filter(Boolean);

const faqItems = [
  {
    q: 'รับซื้อ iPad รุ่นไหนบ้าง?',
    a: 'เรารับซื้อ iPad ทุกตระกูล ทั้ง iPad รุ่นเริ่มต้น (Gen 9, Gen 10), iPad mini, iPad Air (M1, M2) และ iPad Pro (M1, M2, M4) ทุกขนาดหน้าจอและทุกความจุ โดยเฉพาะรุ่นปี 2020 ขึ้นไปจะได้ราคาสูงเป็นพิเศษ',
  },
  {
    q: 'iPad รุ่น Wi-Fi กับ Cellular (ใส่ซิมได้) ราคาต่างกันไหม?',
    a: 'ต่างกันครับ รุ่น Cellular (Wi-Fi + Cellular) จะมีราคารับซื้อสูงกว่ารุ่น Wi-Fi ธรรมดาในสเปกความจุเดียวกัน เนื่องจากมีความยืดหยุ่นในการใช้งานนอกสถานที่มากกว่าและราคาตั้งต้นสูงกว่า',
  },
  {
    q: 'แบตเตอรี่ iPad เสื่อม หรือเช็คสุขภาพแบตไม่ได้ รับซื้อไหม?',
    a: 'รับซื้อครับ แต่ถ้าแบตเตอรี่เสื่อมมาก (ดับเอง ชาร์จไม่เข้า หรือแบตบวมจนจอดัน) เราจะต้องหักลบค่าซ่อม/เปลี่ยนแบตเตอรี่ตามความจริง สำหรับ iPad บางรุ่นที่ไม่โชว์ % แบตในตั้งค่า เราจะใช้โปรแกรมตรวจเช็ค Cycle Count ให้หน้างาน',
  },
  {
    q: 'iPad จอร้าว ทัชสกรีนไม่ได้ หรือจอลาย ขายได้ราคาเท่าไหร่?',
    a: 'รับประเมินเป็นรายเคสครับ โดยเฉพาะ iPad Pro รุ่นที่ใช้จอ OLED (M4) หรือ Mini-LED (M2 12.9") ค่าอะไหล่จอจะสูงมาก หากจอแตกราคาประเมินจะลดลงตามต้นทุนจออะไหล่ แต่เราตีราคาให้อย่างโปร่งใส ไม่กดมั่ว',
  },
  {
    q: 'ติด iCloud หรือเครื่ององค์กร (MDM) ขายได้ไหม?',
    a: 'ต้องปลดล็อก iCloud (Apple ID) และปิด Find My ก่อนขายเสมอครับ ส่วนเครื่องที่ติดล็อก Profile บริษัท (MDM) จะไม่สามารถรับซื้อในราคาปกติได้เลย ต้องนำไปตีเป็นอะไหล่เท่านั้น',
  },
  {
    q: 'มี Apple Pencil หรือ Magic Keyboard ด้วย รับซื้อไหม?',
    a: 'รับซื้อครับ! การขาย iPad พร้อม Apple Pencil (Gen 1, Gen 2, Type-C หรือ Pro) และ Magic Keyboard/Smart Folio จะช่วยเพิ่มมูลค่ารวมให้สูงขึ้น และเราประเมินแยกชิ้นให้ชัดเจน',
  },
  {
    q: 'เครื่องศูนย์ไทย กับเครื่องนอก (เช่น LL, ZP) ราคาต่างกันไหม?',
    a: 'แตกต่างกันเล็กน้อยครับ เครื่องศูนย์ไทย (TH/A) จะเป็นที่ต้องการในตลาดมือสองมากกว่า แต่ถ้าเครื่องนอกมีสภาพสมบูรณ์และใช้งานได้ปกติ ก็ยังได้ราคาที่น่าพอใจมากครับ',
  },
  {
    q: 'ต้องเตรียมตัวอย่างไรก่อนนำ iPad มาขาย?',
    a: '1. แบคอัพข้อมูลขึ้น iCloud 2. Sign out Apple ID 3. รีเซ็ตเครื่อง (Erase All Content and Settings) 4. ชาร์จแบตมาให้พร้อมทดสอบ และเตรียมกล่อง/สายชาร์จมาให้ครบ (ถ้ามี)',
  },
];

const articleJsonLd: Array<Record<string, unknown>> = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: 'รับซื้อ iPad มือสอง ทุกรุ่น Air/Pro/Mini ให้ราคาสูง ประเมินไว',
    description:
      'บริการรับซื้อ iPad มือสองทุกซีรีส์ (Gen, Mini, Air, Pro M1-M4) ประเมินราคาโปร่งใสจากความจุ Cellular สภาพจอ/แบต พร้อมรับซื้อ Apple Pencil จ่ายเงินทันที',
    inLanguage: 'th-TH',
    author: { '@type': 'Organization', name: orgName },
    publisher: { '@type': 'Organization', name: orgName },
    mainEntityOfPage: `${site}/rab-sue-ipad/`,
    datePublished: '2026-03-25',
    dateModified: '2026-03-25',
    image: [new URL('/og-default.png', site).toString()],
    keywords:
      'รับซื้อไอแพด, รับซื้อ iPad, ขาย iPad มือสอง, รับซื้อ iPad Pro m4, รับซื้อ iPad Air, รับซื้อ iPad mini, ประเมินราคา iPad, ขายไอแพดได้ราคาดี',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqItems.map((item) => ({
      '@type': 'Question',
      name: item.q,
      acceptedAnswer: { '@type': 'Answer', text: item.a },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Service',
    name: 'บริการรับซื้อ iPad มือสอง',
    description:
      'รับซื้อ iPad มือสองทุกซีรีส์ iPad / mini / Air / Pro ประเมินราคาโปร่งใส จ่ายเงินทันที ติดต่อ Line @webuy 24 ชั่วโมง ให้บริการทั่วประเทศ',
    provider: { '@type': 'Organization', name: orgName },
    areaServed: serviceAreas.map((area) => ({ '@type': 'AdministrativeArea', name: area })),
    serviceType: 'รับซื้อ iPad มือสอง',
    url: `${site}/rab-sue-ipad/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: site },
      { '@type': 'ListItem', position: 2, name: 'รับซื้อ iPad', item: `${site}/rab-sue-ipad/` },
    ],
  },
];
---

<BaseLayout
  title="รับซื้อไอแพด (iPad) มือสอง | ทุกรุ่น Air/Pro/Mini จ่ายเงินทันที | AMPHON TRADING"
  description="AMPHON TRADING รับซื้อ iPad มือสองทุกรุ่น (Pro M4, Air M2, Mini, Gen) รับ Apple Pencil/Keyboard ประเมินโปร่งใส จ่ายเงินทันที ติดต่อ Line @webuy ตลอด 24 ชั่วโมง"
  pathname="/rab-sue-ipad"
  type="article"
  jsonLd={articleJsonLd}
>
  <article class="container longform">
    <header>
      <p class="kicker">iPad Buyback Guide 2026</p>
      <h1>รับซื้อ iPad มือสอง ทุกรุ่น (Pro, Air, Mini, Gen) ให้ราคาดี ประเมินโปร่งใส จ่ายสดทันที</h1>
      <p class="intro">
        อัปเกรดรุ่นใหม่แล้วไม่รู้จะเอา iPad เครื่องเก่าไปทำอะไร? หรือได้เป็นของขวัญมาแต่ไม่ได้ใช้? <strong>AMPHON TRADING</strong> บริการรับซื้อ iPad มือสองทุกรุ่น ครอบคลุมตั้งแต่ <strong>iPad Pro (ชิป M4 จอ OLED), iPad Air (ชิป M2), iPad Mini ไปจนถึง iPad รุ่นเริ่มต้น (Gen 9, Gen 10)</strong> เราประเมินราคาตามสเปกจริง (Wi-Fi หรือ Cellular, ความจุ, สภาพจอ) พร้อมรับซื้ออุปกรณ์เสริมอย่าง Apple Pencil และ Magic Keyboard ด้วยราคายุติธรรม ไม่กดราคาหน้างาน โอนเงินทันทีหลังตรวจเครื่องเสร็จ พร้อมให้บริการทั่วประเทศตลอด 24 ชั่วโมง ติดต่อเราได้เลยที่ <a class="inline-contact" href="https://line.me/R/ti/p/@webuy" target="_blank" rel="noopener noreferrer">Line @webuy</a> หรือโทร <a class="phone-link" href="tel:0642579353">064-257-9353</a> ครับ
      </p>
    </header>

    <!-- ==================== Section 1 ==================== -->
    <section>
      <h2>ทำไมต้องขาย iPad กับ AMPHON TRADING?</h2>
      <p>
        การตีราคา iPad ต้องอาศัยความเข้าใจในสเปกที่หลากหลาย เพราะภายนอกอาจดูคล้ายกัน แต่ข้างในมีทั้งรุ่น Wi-Fi, Cellular, ชิป A-Series ไปจนถึงชิป M-Series ที่ทรงพลัง:
      </p>
      <ul>
        <li><strong>ประเมินแม่นยำตามสเปก</strong>: เราแยกแยะรุ่นชิป (A14 vs M1 vs M2 vs M4) อย่างชัดเจน และให้ราคา Cellular สูงกว่า Wi-Fi เสมอ</li>
        <li><strong>รับซื้อเหมาพร้อมอุปกรณ์</strong>: ไม่ต้องเหนื่อยแยกขาย Apple Pencil หรือเคสคีย์บอร์ด เราตีราคาเหมารวมบวกเพิ่มให้เลย</li>
        <li><strong>อธิบายราคาทุกจุด</strong>: จอมีรอยขีดข่วน แบตเสื่อม หรือบอดี้บุบ เราบอกเหตุผลการหักราคาอย่างโปร่งใสตามต้นทุนซ่อม</li>
        <li><strong>ขั้นตอนปลอดภัยและรวดเร็ว</strong>: แนะนำวิธีสำรองข้อมูลและล้างเครื่องอย่างปลอดภัย โอนเงินทันทีไม่มีดึงเชิง</li>
      </ul>
    </section>

    <!-- ==================== Section 2 ==================== -->
    <section>
      <h2>ปัจจัยหลักที่กำหนดราคารับซื้อ iPad</h2>
      <p>
        ราคารับซื้อ iPad จะมากหรือน้อย ขึ้นอยู่กับ 5 ปัจจัยหลักนี้:
      </p>

      <h3>1. ซีรีส์ และ เจเนอเรชัน (Series & Generation)</h3>
      <p>
        ซีรีส์ของ iPad แบ่งกลุ่มเป้าหมายชัดเจน:
        <br/>- <strong>iPad Pro</strong>: ได้ราคาสูงสุด โดยเฉพาะชิป M2 และ M4 ที่ใช้จอ Mini-LED และ OLED ตามลำดับ
        <br/>- <strong>iPad Air</strong>: กลุ่มคุ้มค่า (M1, M2) เป็นที่ต้องการมากในกลุ่มนักศึกษา ราคามือสองซื้อง่ายขายคล่อง
        <br/>- <strong>iPad Mini</strong>: หน้าจอเล็ก สเปคแรง ตอบโจทย์เกมเมอร์และสายอ่าน E-Book
        <br/>- <strong>iPad (Gen)</strong>: รุ่นเริ่มต้น (เช่น Gen 9, 10) ราคาจะเข้าถึงง่าย มูลค่ามือสองจึงไม่สูงเท่ากลุ่ม Pro แต่ขายออกไวมาก
      </p>

      <h3>2. ความจุ และ การเชื่อมต่อ (Storage & Network)</h3>
      <p>
        iPad ความจุสูง (256GB, 512GB, 1TB) จะบวกราคาเพิ่มขึ้นมาก และหากเป็นรุ่น <strong>Wi-Fi + Cellular</strong> (ใส่ซิมได้) ผู้รับซื้อจะให้ราคาดีกว่ารุ่น Wi-Fi Only อย่างเห็นได้ชัด เพราะความยืดหยุ่นในการนำไปใช้งานนอกสถานที่
      </p>

      <h3>3. สภาพหน้าจอ (Display Condition)</h3>
      <p>
        จอ iPad มีขนาดใหญ่ จึงเสี่ยงต่อการเกิดรอยขีดข่วน จอร้าว หรือจอเบิร์น (โดยเฉพาะรุ่น OLED) หากหน้าจอมีจุด Dead Pixel สว่างโร่ (White Spot) หรือทัชสกรีนเพี้ยน ราคาจะร่วงแรงตามค่าเปลี่ยนจอแท้
      </p>

      <h3>4. สภาพบอดี้ และ แบตเตอรี่</h3>
      <p>
        บอดี้อะลูมิเนียมของ iPad มักเจอปัญหารอยบุบที่มุม (จากการตก) หรืองอ (Bend) ซึ่งถ้าบอดี้งอจนเห็นชัด จะกระทบราคาสูง ส่วนแบตเตอรี่ หากเสื่อมหรือบวมจนดันหน้าจอขึ้นมา จะต้องตีราคาเผื่อค่าซ่อม
      </p>
      
      <h3>5. อุปกรณ์เสริมแท้ (Accessories)</h3>
      <p>
        กล่องตรงรุ่น, อะแดปเตอร์+สายชาร์จแท้, <strong>Apple Pencil</strong> (Gen 1/2/USB-C/Pro) และ <strong>Magic Keyboard</strong> มีมูลค่าในตัวเองสูง หากขายมาเป็นเซ็ต จะทำให้มูลค่ารวมของดีลนั้นเพิ่มขึ้น
      </p>
    </section>

    <ContactBox heading="เช็คสเปก iPad ของคุณครบแล้วใช่ไหม?" text="ส่งข้อมูลรุ่น ความจุ Cellular/Wi-Fi พร้อมรูปถ่าย มาประเมินราคาฟรีทาง Line @webuy ได้เลย" variant="primary" />

    <!-- ==================== Section 3 ==================== -->
    <section>
      <h2>ขั้นตอนการเตรียม iPad ก่อนนำมาขาย</h2>
      <p>
        เพื่อให้การซื้อขายเป็นไปอย่างรวดเร็วและปลอดภัยต่อข้อมูลของคุณ นี่คือสิ่งที่คุณต้องทำ:
      </p>

      <h3>ขั้นตอนที่ 1: แบคอัพข้อมูล (Backup)</h3>
      <p>
        ไปที่ <em>ตั้งค่า (Settings) > [ชื่อของคุณ] > iCloud > ข้อมูลสำรอง iCloud</em> แล้วกด <strong>สำรองข้อมูลตอนนี้</strong>
      </p>

      <h3>ขั้นตอนที่ 2: ปิด Find My iPad และ Sign Out</h3>
      <p>
        ยังอยู่ที่หน้าตั้งค่า Apple ID เลื่อนลงไปกด <strong>ลงชื่อออก (Sign Out)</strong> กรอกรหัสผ่าน Apple ID ของคุณเพื่อปิด Find My iPad ขั้นตอนนี้สำคัญที่สุด! หากไม่ทำ เครื่องจะติด Activation Lock และไม่มีใครรับซื้อ
      </p>

      <h3>ขั้นตอนที่ 3: รีเซ็ตล้างเครื่อง (Erase All Content)</h3>
      <p>
        ไปที่ <em>ตั้งค่า > ทั่วไป (General) > ถ่ายโอนหรือรีเซ็ต iPad > <strong>ลบข้อมูลและการตั้งค่าทั้งหมด</strong></em> เครื่องจะรีบูตและกลับสู่หน้าสวัสดี (Hello) 
      </p>
      
      <div class="highlight-box">
        <strong>ข้อควรระวัง:</strong> หาก iPad ใส่ซิม (Cellular) อยู่ อย่าลืมถอดซิมการ์ดของคุณออกก่อนส่งมอบเครื่องให้เรานะครับ
      </div>
    </section>

    <!-- ==================== Section 4 ==================== -->
    <section>
      <h2>พื้นที่ให้บริการรับซื้อ iPad ทั่วประเทศ</h2>
      <p>
        AMPHON TRADING บริการรับซื้อทั่วประเทศ ไม่ว่าคุณจะอยู่ที่ไหนก็ขายได้:
      </p>
      <h3>1. กรุงเทพฯ และปริมณฑล</h3>
      <p>
        สามารถแชทตกลงราคา และนัดหมายรับเครื่อง/ส่งเครื่องได้โดยตรง ทีมงานตรวจสเปกและโอนเงินทันทีที่จุดนัดหมาย
      </p>
      <h3>2. ต่างจังหวัด ({serviceAreas.filter(a => !['กรุงเทพมหานคร','ปริมณฑล'].includes(a)).join(', ')} ฯลฯ)</h3>
      <p>
        ส่งรายละเอียดรูปภาพมาประเมินทาง Line เมื่อตกลงราคาเรียบร้อย คุณสามารถแพ็คสินค้าส่งพัสดุ (Kerry, Flash, EMS) โดยแนะนำให้ <strong>ถ่ายวิดีโอตอนแพ็คและซื้อประกันพัสดุ</strong> เมื่อของถึงเราและตรวจเช็คเรียบร้อย โอนเงินให้เต็มจำนวนทันที
      </p>
    </section>

    <!-- ==================== FAQ Section ==================== -->
    <section class="faq">
      <h2>คำถามที่พบบ่อย (FAQ) รับซื้อ iPad</h2>
      {faqItems.map((item) => (
        <details>
          <summary>{item.q}</summary>
          <p>{item.a}</p>
        </details>
      ))}
    </section>

    <!-- ==================== Internal Links ==================== -->
