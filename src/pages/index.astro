---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { fetchPosts, isWordpressConfigured } from '../lib/wordpress';
import { getSiteOrigin } from '../lib/site';

const configured = isWordpressConfigured();
const allPosts = configured ? await fetchPosts() : [];
const recent = allPosts.slice(0, 10);
const site = getSiteOrigin();
const orgName = import.meta.env.PUBLIC_ORG_NAME ?? 'AMPHON TRADING';
const orgLogo = import.meta.env.PUBLIC_ORG_LOGO_URL ?? '/favicon.svg';
const socialRaw = import.meta.env.PUBLIC_ORG_SAME_AS ?? '';
const socialLinks = socialRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);
const businessPhone = import.meta.env.PUBLIC_BUSINESS_PHONE ?? '+66-64-257-9353';
const serviceAreasRaw =
	import.meta.env.PUBLIC_SERVICE_AREAS ??
	'กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี,มหาสารคาม,สุรินทร์';
const serviceAreas = serviceAreasRaw
	.split(',')
	.map((item) => item.trim())
	.filter(Boolean);
const mapUrl =
	import.meta.env.PUBLIC_GOOGLE_MAP_URL ??
	'https://maps.google.com/?q=13.7563,100.5018';
const techPillars = [
	{
		title: 'AI-Assisted Pricing',
		text: 'ประเมินเบื้องต้นเร็วขึ้นจากข้อมูลรุ่นและสภาพสินค้า พร้อมทีมงานตรวจซ้ำทุกเคส',
	},
	{
		title: 'Traceable Workflow',
		text: 'ทุกขั้นตอนมีหลักฐานการคุยและการตกลงราคา ช่วยให้ตรวจสอบย้อนหลังได้',
	},
	{
		title: '24/7 Response Layer',
		text: 'มีช่องทางติดต่อหลักผ่าน LINE @webuy พร้อมการตอบกลับต่อเนื่องตลอดวัน',
	},
	{
		title: 'Knowledge Hub',
		text: 'คอนเทนต์บทความจำนวนมากช่วยให้ลูกค้าตัดสินใจจากข้อมูล ไม่ใช่การคาดเดา',
	},
];

const faqItems = [
	{
		question: 'รับประเมินราคาสินค้าอย่างไร และใช้เวลานานไหม?',
		answer: 'เพียงส่งรูปภาพสินค้าให้ชัดเจน (ถ่ายรอบเครื่อง จอ และตำหนิ) พร้อมแจ้งรุ่น สเปก และอุปกรณ์ที่มีผ่านทาง Line @webuy ทีมงานผู้เชี่ยวชาญของเราจะทำการประเมินและแจ้งช่วงราคารับซื้อเบื้องต้นให้คุณทราบภายใน 15-30 นาทีในเวลาทำการ',
	},
	{
		question: 'รับซื้อโน๊ตบุ๊คที่เปิดไม่ติด หรือจอแตกหรือไม่?',
		answer: 'รับซื้อครับ แม้เครื่องจะเปิดไม่ติด บอร์ดช็อต หรือหน้าจอแตก เราก็ยังสามารถรับซื้อเพื่อนำไปเป็นอะไหล่หมุนเวียน (Spare Parts) ได้ โดยราคาจะถูกประเมินจากชิ้นส่วนที่ยังสามารถใช้งานได้ เช่น RAM, SSD, CPU, หรือเคส',
	},
	{
		question: 'ต้องล้างข้อมูล (Wipe Data) ก่อนส่งเครื่องไหม?',
		answer: 'ทางเราแนะนำให้ลูกค้าทำการ Backup ข้อมูลสำคัญและล้างเครื่อง (Factory Reset) ก่อนส่งมอบเสมอเพื่อความสบายใจสูงสุด อย่างไรก็ตาม หากลูกค้าทำไม่เป็นหรือไม่สะดวก ทีมงานของเรามีบริการช่วยล้างข้อมูลด้วยซอฟต์แวร์ลบข้อมูลมาตรฐานสูงต่อหน้าลูกค้า หรือส่งหลักฐานการล้างเครื่องให้ดูหลังจบงาน',
	},
	{
		question: 'เครื่องติด Apple ID / iCloud หรือ MDM บริษัท ขายได้ไหม?',
		answer: 'หากเครื่องติด Apple ID (Activation Lock) ผู้ขายจำเป็นต้องใส่รหัสผ่านเพื่อปลดล็อกก่อนการรับซื้อครับ หากลืมรหัสผ่านหรือเป็นเครื่องที่ติดล็อก Profile ขององค์กร (MDM) ทางเราจะไม่สามารถรับซื้อในราคาเครื่องปกติได้ แต่อาจตีราคาเป็นชิ้นส่วนอะไหล่แทน',
	},
	{
		question: 'ขายโน๊ตบุ๊ค AI PC หรือ Copilot+ PC ได้ราคาดีกว่ารุ่นปกติไหม?',
		answer: 'แน่นอนครับ ในปี 2026 ตลาดมีความต้องการโน๊ตบุ๊คที่มี NPU (Neural Processing Unit) สูงมาก เช่น เครื่องที่ใช้ชิป Snapdragon X Elite หรือ Intel Core Ultra หากคุณมีเครื่องกลุ่มนี้ จะได้รับราคาประเมินที่สูงกว่าโน๊ตบุ๊คสถาปัตยกรรมเก่าอย่างเห็นได้ชัด',
	},
	{
		question: 'อยู่ต่างจังหวัด (เช่น อุบลราชธานี ขอนแก่น เชียงใหม่) ขายได้ไหม?',
		answer: 'ขายได้แน่นอนครับ! เรามีลูกค้าระบบจัดส่งพัสดุจากทั่วประเทศ ขั้นตอนคือ: ตกลงราคาเบื้องต้นผ่าน Line > ลูกค้าแพ็คเครื่องอย่างแน่นหนาและจัดส่งผ่าน Kerry/Flash (แนะนำให้ทำประกันพัสดุ) > เมื่อของถึงมือทีมงานและสภาพตรงตามที่แจ้ง เราโอนเงินเข้าบัญชีทันที',
	},
	{
		question: 'กล้องเลนส์ขึ้นรา หรือมีฝุ่นข้างใน รับซื้อไหม?',
		answer: 'รับประเมินครับ เลนส์ที่มีราหรือฝ้าจะถูกประเมินราคาลดลงตามค่าใช้จ่ายในการส่งช่างล้างเลนส์ (Clean & CLA) หากรากินลึกจนทำลายสารเคลือบชิ้นแก้ว (Coating) ราคาจะตกลงค่อนข้างมาก แต่เรายินดีประเมินให้อย่างตรงไปตรงมาครับ',
	},
	{
		question: 'การจ่ายเงินเป็นรูปแบบไหน?',
		answer: 'เมื่อเราได้รับเครื่องและตรวจสภาพยืนยันความถูกต้องเรียบร้อย เราทำการ "โอนเงินสดเต็มจำนวน" เข้าบัญชีธนาคารของผู้ขายทันที (Real-time Bank Transfer) ปลอดภัย รวดเร็ว และสามารถตรวจสอบสลิปได้ทันที',
	},
	{
		question: 'รับซื้อเครื่องขุดเหรียญคริปโต (Mining Rig) หรือการ์ดจอที่ผ่านการขุดไหม?',
		answer: 'เรารับประเมินครับ แต่ผู้ขายต้องแจ้งตามความจริงว่าผ่านการขุดมา (Mining) เนื่องจากสภาพซิลิโคน พัดลม และเม็ดแรม (VRAM) บนการ์ดจอจะเสื่อมสภาพเร็วกว่าปกติ ราคาประเมินจะถูกหักค่าความเสื่อมตามมาตรฐาน แต่ดีกว่าการปล่อยทิ้งไว้ให้หมดมูลค่าครับ',
	},
	{
		question: 'ติดต่อช่วงเวลาไหนได้บ้าง?',
		answer: 'แพลตฟอร์มของเราออกแบบมาเพื่อตอบโจทย์คนรุ่นใหม่ คุณสามารถทัก Line @webuy ทิ้งไว้ได้ตลอด 24 ชั่วโมง (24/7 Service) แม้จะเป็นช่วงดึกหรือวันหยุดยาว เรามีทีมงานคอยแสตนด์บายเพื่อตอบคำถามและประเมินราคาให้เร็วที่สุด',
	},
	{
		question: 'มีบริการรับซื้อถึงที่ (On-site Pick up) ไหม?',
		answer: 'สำหรับลูกค้าในเขตกรุงเทพมหานครและปริมณฑล หากสินค้ามีจำนวนมาก (เช่น โละคอมพิวเตอร์สำนักงาน) หรือเป็นสินค้ามูลค่าสูง ทางเรามีบริการนัดรับถึงที่ (On-site) เพื่อความสะดวกปลอดภัย กรุณาแชทสอบถามเพื่อเช็คคิวและพื้นที่ให้บริการครับ',
	},
	{
		question: 'นำเครื่องเก่ามา "เทิร์น (Trade-in)" เครื่องใหม่ได้ไหม?',
		answer: 'ปัจจุบัน AMPHON TRADING เน้นรับซื้อและจ่ายเป็น "เงินสด" เป็นหลักครับ ซึ่งให้ความยืดหยุ่นกับผู้ขายมากกว่า เพราะคุณสามารถนำเงินก้อนนี้ไปเลือกซื้อเครื่องใหม่แบรนด์ใดหรือร้านใดก็ได้ที่คุณต้องการ โดยไม่ต้องถูกผูกมัดกับสต๊อกของร้านเรา',
	},
	{
		question: 'MacBook แบตเสื่อม (Service Recommended) กระทบราคาเยอะไหม?',
		answer: 'มีผลกระทบครับ เนื่องจากค่าเปลี่ยนแบตเตอรี่แท้ของ MacBook รุ่นใหม่ๆ ค่อนข้างสูง เราจะใช้ Cycle Count และ Battery Health % เป็นตัวอ้างอิง หากต้องเปลี่ยนแบต เราจะหักลบราคาตามต้นทุนอะไหล่แบบโปร่งใส ไม่กดราคามั่ว',
	},
	{
		question: 'ขายกล้องฟิล์มเก่าๆ (Film Camera) รับซื้อไหม?',
		answer: 'รับซื้อครับ! กล้องฟิล์มทั้งแบบ SLR, Rangefinder, Point & Shoot และ Medium Format (เช่น Leica, Contax, Hasselblad) มีมูลค่าในตลาดนักสะสมสูงมาก หากคุณมีกล้องฟิล์มที่เก็บไว้นาน ถ่ายรูปส่งมาให้เราตรวจสอบรุ่นและราคาได้เลย',
	},
	{
		question: 'ถ้าลืมรหัสผ่านเข้าเครื่อง Windows ทำอย่างไร?',
		answer: 'ไม่เป็นไรครับ ขอแค่เครื่องไม่ใช่เครื่องที่ถูกโจรกรรมมา (เราเช็ค Serial Number เสมอ) ทีมงานสามารถใช้อุปกรณ์พิเศษเพื่อ Format ไดรฟ์และล้างข้อมูลเก่าออกทั้งหมดโดยไม่ต้องเข้าสู่ระบบเดิมได้',
	},
];

const homeJsonLd: Array<Record<string, unknown>> = [
	{
		'@context': 'https://schema.org',
		'@type': 'WebSite',
