# URL ของ WordPress (ไม่มี slash ท้าย) — ต้องเปิด REST API แบบ public
# ตัวอย่าง: https://blog.example.com หรือ https://example.com
PUBLIC_WORDPRESS_URL=https://your-wordpress-site.com

# โดเมนจริงของเว็บไซต์ Astro สำหรับใช้ generate sitemap
# ตัวอย่าง: https://www.your-astro-site.com
SITE_URL=https://www.your-astro-site.com

# ข้อมูลแบรนด์สำหรับ SEO/AEO/GEO
PUBLIC_SITE_NAME=AMPHON TRADING
PUBLIC_SITE_LOCALE=th_TH
PUBLIC_SITE_DESCRIPTION=AMPHON TRADING (อำพล เทรดดิ้ง) บริการรับซื้อสินค้าไอทีมือสอง ประเมินราคาโปร่งใส จ่ายเงินทันที ติดต่อ Line @webuy ตลอด 24 ชั่วโมง
PUBLIC_ORG_NAME=AMPHON TRADING
PUBLIC_ORG_LOGO_URL=/favicon.svg

# ใส่หลาย URL คั่นด้วย comma เช่น https://facebook.com/xxx,https://x.com/xxx
PUBLIC_ORG_SAME_AS=

# ใส่ค่าแบบ @yourhandle (ถ้ามี)
PUBLIC_TWITTER_SITE=

# LocalBusiness / Contact page
PUBLIC_BUSINESS_PHONE=+66-64-257-9353
PUBLIC_OPENING_HOURS=เปิดบริการทุกวัน 24 ชั่วโมง
PUBLIC_SERVICE_AREAS=กรุงเทพมหานคร,ปริมณฑล,อุบลราชธานี,ขอนแก่น,นครราชสีมา,อุดรธานี
PUBLIC_ADDRESS_LOCALITY=กรุงเทพมหานคร
PUBLIC_ADDRESS_REGION=ประเทศไทย
PUBLIC_POSTAL_CODE=10200
PUBLIC_GOOGLE_MAP_URL=https://maps.google.com/?q=13.7563,100.5018
PUBLIC_GOOGLE_MAP_EMBED=https://www.google.com/maps?q=13.7563,100.5018&z=12&output=embed
